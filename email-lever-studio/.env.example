CLAUDE_API_KEY=sk-ant-your-key-here
# optional: CLAUDE_MODEL=claude-sonnet-5

# Python contextual bandit service (bandit_mvp/service.py). Default shown.
# BANDIT_URL=http://127.0.0.1:8000

# Postgres for real outcomes / the 50-email baseline. Empty today; the bandit runs
# fine without it. Set this and implement bandit_mvp/db.py to link real data up.
# DATABASE_URL=postgresql://user:pass@localhost:5432/email_marketing

# Dashboard: in dev, mock data is used by default (no API required).
# Set to false to hit /api/dashboard through the Vite proxy (requires npm run dev:api on :3001).
# VITE_USE_MOCK_DASHBOARD=false
